<Page
    x:Class="FluentPDF.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Padding="20,20,20,0">
        <StackPanel Spacing="32">

            <!-- 外观 -->
            <StackPanel Spacing="3">
                <TextBlock x:Uid="AppearanceGroup" FontSize="14" Margin="0,0,0,6" FontWeight="SemiBold"/>

                <muxc:Expander IsExpanded="False" HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE706;" Width="25" FontSize="20"/>
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock x:Uid="ThemeTitle" FontSize="14.4"/>
                                <TextBlock x:Uid="ThemeSubtitle" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>
                    <muxc:RadioButtons x:Name="RbTheme" SelectionChanged="RbTheme_SelectionChanged"
                                       Padding="12,0,0,12">
                        <RadioButton x:Uid="ThemeSystem" Tag="System"/>
                        <RadioButton x:Uid="ThemeLight" Tag="Light"/>
                        <RadioButton x:Uid="ThemeDark" Tag="Dark"/>
                    </muxc:RadioButtons>
                </muxc:Expander>

                <muxc:Expander IsExpanded="False" HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE2B1;" Width="25" FontSize="20"/>
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock x:Uid="MaterialTitle" FontSize="14.4"/>
                                <TextBlock x:Uid="MaterialSubtitle" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                        </StackPanel>
                    </muxc:Expander.Header>
                    <muxc:RadioButtons x:Name="RbMaterial" SelectionChanged="RbMaterial_SelectionChanged"
                                       Padding="12,0,0,12">
                        <RadioButton Content="Mica" Tag="Mica"/>
                        <RadioButton Content="Acrylic" Tag="Acrylic"/>
                    </muxc:RadioButtons>
                </muxc:Expander>


            </StackPanel>

            <!-- 声音 -->
            <StackPanel Spacing="3">
                <TextBlock x:Uid="SoundGroup" FontSize="14" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <controls:SettingsCard x:Uid="Settings_SoundCard" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Stretch" MinHeight="70" Padding="16,0">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE767;"/>
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="SoundToggle" HorizontalAlignment="Right"
                                  Toggled="SoundToggle_Toggled"/>
                </controls:SettingsCard>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="3">
                <TextBlock x:Uid="AboutGroup" FontSize="14" Margin="0,0,0,6" FontWeight="SemiBold"/>
                <muxc:Expander IsExpanded="False" HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left" MinHeight="70">
                    <muxc:Expander.Header>
                        <Grid HorizontalAlignment="Stretch" Margin="1,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="ImgAppIcon" Grid.Column="0" Width="20" Height="20"
                                   Stretch="Uniform" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="21,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtAppName" FontSize="14.4"/>
                                <TextBlock x:Name="TxtCopyright" FontSize="12" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtVersion" Grid.Column="2" FontSize="14.4"
                                       Opacity="0.7" VerticalAlignment="Center"/>
                        </Grid>
                    </muxc:Expander.Header>
                    <StackPanel Padding="12,0,0,12">
                        <HyperlinkButton Click="OpenExternalLink"
                                         Tag="https://github.com/Furry-Xiyi/UWP-Blank-Template"
                                         HorizontalAlignment="Left">
                            <TextBlock x:Uid="GithubLink"/>
                        </HyperlinkButton>
                    </StackPanel>
                </muxc:Expander>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
