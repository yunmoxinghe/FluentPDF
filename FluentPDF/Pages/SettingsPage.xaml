<Page
    x:Class="FluentPDF.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    Background="Transparent">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6"/>
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="20,0">
        <Grid>
            <StackPanel MaxWidth="1000"
                        HorizontalAlignment="Stretch"
                        Spacing="{StaticResource SettingsCardSpacing}">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                    <RepositionThemeTransition IsStaggeringEnabled="False"/>
                </StackPanel.ChildrenTransitions>

                <!-- 页面标题 -->
                <TextBlock x:Uid="Settings_PageTitle"
                           Style="{ThemeResource TitleTextBlockStyle}"
                           Margin="1,36,0,0"/>

                <!-- 外观 -->
                <TextBlock x:Uid="AppearanceGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsExpander x:Uid="Settings_ThemeExpander"
                                           IsExpanded="False"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE706;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <muxc:RadioButtons x:Name="RbTheme" SelectionChanged="RbTheme_SelectionChanged">
                                <RadioButton x:Uid="ThemeSystem" Tag="System"/>
                                <RadioButton x:Uid="ThemeLight"  Tag="Light"/>
                                <RadioButton x:Uid="ThemeDark"   Tag="Dark"/>
                            </muxc:RadioButtons>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <controls:SettingsExpander x:Uid="Settings_MaterialExpander"
                                           IsExpanded="False"
                                           HeaderIcon="{ui:FontIcon Glyph=&#xE2B1;}">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <muxc:RadioButtons x:Name="RbMaterial" SelectionChanged="RbMaterial_SelectionChanged">
                                <RadioButton Content="Mica"    Tag="Mica"/>
                                <RadioButton Content="Acrylic" Tag="Acrylic"/>
                            </muxc:RadioButtons>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 声音 -->
                <TextBlock x:Uid="SoundGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="Settings_SoundCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE767;}">
                    <ToggleSwitch x:Name="SoundToggle" Toggled="SoundToggle_Toggled"/>
                </controls:SettingsCard>

                <!-- 启动行为 -->
                <TextBlock x:Uid="StartupGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="Settings_ShowWelcomeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE80F;}">
                    <ToggleSwitch x:Name="ShowWelcomeToggle" Toggled="ShowWelcomeToggle_Toggled"/>
                </controls:SettingsCard>

                <controls:SettingsCard x:Uid="Settings_AllowCloseWelcomeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE711;}">
                    <ToggleSwitch x:Name="AllowCloseWelcomeToggle" Toggled="AllowCloseWelcomeToggle_Toggled"/>
                </controls:SettingsCard>

                <!-- 学校模式 -->
                <TextBlock x:Uid="SchoolModeGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="Settings_SchoolModeCard"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE7BE;}">
                    <ToggleSwitch x:Name="SchoolModeToggle" Toggled="SchoolModeToggle_Toggled"/>
                </controls:SettingsCard>

    <!-- 渲染引擎 -->
                <TextBlock Text="渲染引擎"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsExpander HeaderIcon="{ui:FontIcon Glyph=&#xE9F5;}"
                                           Header="PDF 渲染引擎"
                                           Description="PDFium 后端仍在开发中，暂不可用"
                                           IsExpanded="False"
                                           IsEnabled="False">
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <muxc:RadioButtons x:Name="RbPdfEngine" SelectionChanged="RbPdfEngine_SelectionChanged">
                                <RadioButton Content="Windows.Data.Pdf（系统内置，速度快）" Tag="Windows"/>
                                <RadioButton Content="PDFium（支持密码保护）"               Tag="PDFium"/>
                            </muxc:RadioButtons>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 关于 -->
                <TextBlock x:Uid="AboutGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsExpander x:Name="AboutExpander"
                                           IsExpanded="False"
                                           HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/Square44x44Logo.scale-200.png}">
                    <controls:SettingsExpander.Header>
                        <TextBlock x:Name="TxtAppName" FontSize="14.4"/>
                    </controls:SettingsExpander.Header>
                    <controls:SettingsExpander.Description>
                        <TextBlock x:Name="TxtCopyright" FontSize="12" Opacity="0.8"/>
                    </controls:SettingsExpander.Description>
                    <TextBlock x:Name="TxtVersion"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               IsTextSelectionEnabled="True"/>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard HorizontalContentAlignment="Left"
                                               ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Orientation="Vertical">
                                <HyperlinkButton Click="OpenExternalLink"
                                                 Tag="https://github.com/yunmoxinghe/FluentPDF">
                                    <TextBlock x:Uid="GithubLink"/>
                                </HyperlinkButton>
                                <HyperlinkButton Click="OpenExternalLink"
                                                 Tag="https://github.com/Furry-Xiyi/UWP-Blank-Template">
                                    <TextBlock x:Uid="TemplateLink"/>
                                </HyperlinkButton>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 底部留白 -->
                <Border Height="36"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
