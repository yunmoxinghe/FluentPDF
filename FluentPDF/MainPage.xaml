<Page
    x:Class="FluentPDF.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Loaded="MainPage_Loaded">

    <Grid>
        <muxc:TabView x:Name="PdfTabView"
                      VerticalAlignment="Stretch"
                      TabWidthMode="Equal"
                      AddTabButtonClick="TabView_AddTabButtonClick"
                      TabCloseRequested="TabView_TabCloseRequested">

            <!-- 左侧：为系统图标/左侧系统按钮留出空间 -->
            <muxc:TabView.TabStripHeader>
                <Grid x:Name="ShellTitlebarInset" Background="Transparent"/>
            </muxc:TabView.TabStripHeader>

            <!-- 右侧：拖拽区域占满剩余空间，系统按钮保留固定占位 -->
            <muxc:TabView.TabStripFooter>
                <Grid x:Name="TitleBarDragGrid" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- 系统按钮占位（最右侧） -->
                        <ColumnDefinition x:Name="CustomDragRegionColumn" Width="188"/>
                    </Grid.ColumnDefinitions>

                    <!-- 可拖拽区域，必须靠近系统按钮 -->
                    <Grid x:Name="CustomDragRegion"
                          Grid.Column="0"
                          Background="Transparent"/>
                </Grid>
            </muxc:TabView.TabStripFooter>

        </muxc:TabView>
    </Grid>
</Page>
