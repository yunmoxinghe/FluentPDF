<Application
    x:Class="FluentPDF.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <muxc:XamlControlsResources>
            <muxc:XamlControlsResources.MergedDictionaries>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Light">
                            <!-- LayerFillColorDefault on Mica: 50% white -->
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#80FFFFFF"/>
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <!-- LayerFillColorDefault on Mica: ~30% dark -->
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="#4C3A3A3A"/>
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </muxc:XamlControlsResources.MergedDictionaries>
        </muxc:XamlControlsResources>
    </Application.Resources>
</Application>
